# Copy to .env on the deploy box (never commit .env).
# Values come from the Cloudflare Zero Trust dashboard / API:
#   CF_ACCESS_AUD        — the Access application's AUD tag for
#                          taste-twin.graham-williams.com
#   CF_ACCESS_TEAM_DOMAIN — the Zero Trust team domain
CF_ACCESS_AUD=paste-the-access-app-aud-tag-here
CF_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com

# View-only mode. The box can't scrape Letterboxd live (Cloudflare bot
# management challenges its server IP), so the box serves pre-generated
# reports only: homepage form hidden, POST /run refused, no worker/ingest.
# The BOX gets "1" from docker-compose.yml regardless of this file — so this
# is left at 0 here to avoid surprising a local full-mode dev copy.
# New reports are generated on Graham's Mac via scripts/publish.py.
TASTE_TWIN_VIEWER_MODE=0
